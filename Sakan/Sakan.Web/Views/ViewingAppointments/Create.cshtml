@model Sakan.Application.DTO.CreateViewingAppointmentDto
@{
    ViewData["Title"] = "Request viewing";
}

<h1>Request viewing</h1>
<form asp-action="Create" method="post">
    <input type="hidden" asp-for="ListingId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="ScheduledAt" class="form-label"></label>
        <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="MeetingType" class="form-label"></label>
        <select asp-for="MeetingType" class="form-select" asp-items="Html.GetEnumSelectList<Sakan.Domain.Enums.MeetingType>()"></select>
    </div>
    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Submit request</button>
</form>