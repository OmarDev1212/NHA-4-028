@using Sakan.Domain.Enums
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var propertiesActive = controller is "Listings" or "Properties";
    var servicesActive = controller is "ViewingAppointments" or "RentalApplications" or "OwnershipTransfers" or "MaintenanceRequests" or "Notifications" or "User" or "Role";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Sakan — discover, rent, and transfer property remotely." />
    <link rel="shortcut icon" href="~/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/fonts/icomoon/style.css" />
    <link rel="stylesheet" href="~/fonts/flaticon/font/flaticon.css" />
    <link rel="stylesheet" href="~/css/tiny-slider.css" />
    <link rel="stylesheet" href="~/css/aos.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - Sakan" : "Sakan")</title>
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="site-mobile-menu site-navbar-target">
        <div class="site-mobile-menu-header">
            <div class="site-mobile-menu-close">
                <span class="icofont-close js-menu-toggle"></span>
            </div>
        </div>
        <div class="site-mobile-menu-body"></div>
    </div>

    <nav class="site-nav">
        <div class="container">
            <div class="menu-bg-wrap">
                <div class="site-navigation">
                    <a asp-controller="Home" asp-action="Index" class="logo m-0 float-start">Sakan</a>

                    <ul class="js-clone-nav d-none d-lg-inline-block text-start site-menu float-end">
                        <li class="@(controller == "Home" ? "active" : "")">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="has-children @(propertiesActive ? "active" : "")">
                            <a asp-controller="Listings" asp-action="Index">Properties</a>
                            <ul class="dropdown">
                                <li><a asp-controller="Listings" asp-action="Index">All Properties</a></li>
                                <li><a asp-controller="Listings" asp-action="Index" asp-route-listingType="@ListingType.ForSale">Buy Property</a></li>
                                <li><a asp-controller="Listings" asp-action="Index" asp-route-listingType="@ListingType.ForRent">Rent Property</a></li>
                                @if (isAuthenticated)
                                {
                                    <li><a asp-controller="Listings" asp-action="MyListings">My Listings</a></li>
                                    <li><a asp-controller="Listings" asp-action="Create">List for Sale / Rent</a></li>
                                    <li><a asp-controller="Properties" asp-action="Index">Manage Properties</a></li>
                                }
                            </ul>
                        </li>
                        <li class="has-children @(servicesActive ? "active" : "")">
                            <a href="#">Services</a>
                            <ul class="dropdown">
                                @if (isAuthenticated)
                                {
                                    <li><a asp-controller="ViewingAppointments" asp-action="Index">Viewing Appointments</a></li>
                                    <li><a asp-controller="RentalApplications" asp-action="MyApplications">Rental Applications</a></li>
                                    <li><a asp-controller="OwnershipTransfers" asp-action="Index">Ownership Transfer</a></li>
                                    <li><a asp-controller="MaintenanceRequests" asp-action="Index">Maintenance</a></li>
                                    <li><a asp-controller="Notifications" asp-action="Index">Notifications</a></li>
                                    <li class="has-children">
                                        <a href="#">Admin</a>
                                        <ul class="dropdown">
                                            <li><a asp-controller="User" asp-action="Index">Users</a></li>
                                            <li><a asp-controller="Role" asp-action="Index">Roles</a></li>
                                        </ul>
                                    </li>
                                }
                                else
                                {
                                    <li><a asp-controller="Account" asp-action="Login">Sign in to use services</a></li>
                                }
                            </ul>
                        </li>
                        <li class="@(controller == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")">
                            <a asp-controller="Home" asp-action="Privacy">About</a>
                        </li>
                        @if (isAuthenticated)
                        {
                            <li>
                                <a href="#" id="nav-logout-link">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="@(controller == "Account" ? "active" : "")">
                                <a asp-controller="Account" asp-action="Login">Contact Us</a>
                            </li>
                        }
                    </ul>

                    @if (isAuthenticated)
                    {
                        <form id="nav-logout-form" asp-controller="Account" asp-action="Logout" method="post" class="d-none">
                            @Html.AntiForgeryToken()
                        </form>
                    }

                    <a href="#"
                       class="burger light me-auto float-end mt-1 site-menu-toggle js-menu-toggle d-inline-block d-lg-none"
                       data-toggle="collapse"
                       data-target="#main-navbar">
                        <span></span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    @await RenderSectionAsync("Hero", required: false)

    <div class="section pt-4 pb-5">
        <div class="container">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["WelcomeMessage"] is string welcome)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @welcome
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="site-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4">
                    <div class="widget">
                        <h3>Sakan</h3>
                        <p class="text-black-50">Discover properties, schedule virtual viewings, rent remotely, and complete digital ownership transfers.</p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="widget">
                        <h3>Explore</h3>
                        <ul class="list-unstyled links">
                            <li><a asp-controller="Listings" asp-action="Index">Browse listings</a></li>
                            @if (isAuthenticated)
                            {
                                <li><a asp-controller="ViewingAppointments" asp-action="Index">Viewings</a></li>
                                <li><a asp-controller="RentalApplications" asp-action="MyApplications">Rentals</a></li>
                                <li><a asp-controller="OwnershipTransfers" asp-action="Index">Transfers</a></li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="widget">
                        <h3>Account</h3>
                        <ul class="list-unstyled links">
                            @if (isAuthenticated)
                            {
                                <li><a asp-controller="Notifications" asp-action="Index">Notifications</a></li>
                                <li><a asp-controller="Listings" asp-action="MyListings">My listings</a></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link p-0 align-baseline">Logout</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                                <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                            }
                            <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-12 text-center">
                    <p class="mb-0">&copy; @DateTime.Now.Year Sakan. All rights reserved.</p>
                </div>
            </div>
        </div>
    </div>

    <div id="overlayer"></div>
    <div class="loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tiny-slider.js"></script>
    <script src="~/js/aos.js"></script>
    <script src="~/js/navbar.js"></script>
    <script src="~/js/counter.js"></script>
    <script src="~/js/custom.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (isAuthenticated)
    {
        <script>
            document.getElementById('nav-logout-link')?.addEventListener('click', function (e) {
                e.preventDefault();
                document.getElementById('nav-logout-form')?.submit();
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
