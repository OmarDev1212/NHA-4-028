@model Sakan.Application.DTO.PropertyDto

@{
    ViewData["Title"] = "Property Details";
}

<h1>Details</h1>

<div>
    <h4>@Model.Title</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.PropertyType</dd>

        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">
            @Model.Street, @Model.City, @Model.State @Model.PostalCode, @Model.Country
        </dd>

        <dt class="col-sm-2">Area (m²)</dt>
        <dd class="col-sm-10">@Model.AreaSqm</dd>

        <dt class="col-sm-2">Bedrooms</dt>
        <dd class="col-sm-10">@Model.Bedrooms</dd>

        <dt class="col-sm-2">Bathrooms</dt>
        <dd class="col-sm-10">@Model.Bathrooms</dd>

        <dt class="col-sm-2">Year Built</dt>
        <dd class="col-sm-10">@Model.YearBuilt</dd>

        <dt class="col-sm-2">Legal Status</dt>
        <dd class="col-sm-10">@Model.LegalStatus</dd>

        <dt class="col-sm-2">Owner</dt>
        <dd class="col-sm-10">@Model.CurrentOwnerId</dd>

        <dt class="col-sm-2">Features</dt>
        <dd class="col-sm-10">
            @if (Model.Features?.Count > 0)
            {
                @string.Join(", ", Model.Features)
            }
            else
            {
                <span class="text-muted">None</span>
            }
        </dd>

        <dt class="col-sm-2">Photos</dt>
        <dd class="col-sm-10">
            @if (Model.ImagesNames?.Count > 0)
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var image in Model.ImagesNames)
                    {
                        <img src="~/Uploads/Properties/@image" alt="Property photo" class="img-thumbnail" style="max-height: 120px;" />
                    }
                </div>
            }
            else
            {
                <span class="text-muted">None</span>
            }
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
