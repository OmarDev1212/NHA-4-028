@model Sakan.Application.DTO.PropertyDto

<div class="form-group mb-3">
    <label asp-for="Title" class="control-label"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="form-group mb-3">
    <label asp-for="PropertyType" class="control-label"></label>
    <select asp-for="PropertyType" class="form-control" asp-items="ViewBag.PropertyType">
        <option value="">-- Select type --</option>
    </select>
    <span asp-validation-for="PropertyType" class="text-danger"></span>
</div>

<div class="form-group mb-3">
    <label asp-for="Street" class="control-label"></label>
    <input asp-for="Street" class="form-control" />
    <span asp-validation-for="Street" class="text-danger"></span>
</div>

<div class="row">
    <div class="col-md-6 form-group mb-3">
        <label asp-for="City" class="control-label"></label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger"></span>
    </div>
    <div class="col-md-6 form-group mb-3">
        <label asp-for="State" class="control-label"></label>
        <input asp-for="State" class="form-control" />
        <span asp-validation-for="State" class="text-danger"></span>
    </div>
</div>

<div class="row">
    <div class="col-md-6 form-group mb-3">
        <label asp-for="Country" class="control-label"></label>
        <input asp-for="Country" class="form-control" />
        <span asp-validation-for="Country" class="text-danger"></span>
    </div>
    <div class="col-md-6 form-group mb-3">
        <label asp-for="PostalCode" class="control-label"></label>
        <input asp-for="PostalCode" class="form-control" />
        <span asp-validation-for="PostalCode" class="text-danger"></span>
    </div>
</div>

<div class="form-group mb-3">
    <label asp-for="AreaSqm" class="control-label"></label>
    <input asp-for="AreaSqm" class="form-control" />
    <span asp-validation-for="AreaSqm" class="text-danger"></span>
</div>

<div class="row">
    <div class="col-md-4 form-group mb-3">
        <label asp-for="Bedrooms" class="control-label"></label>
        <input asp-for="Bedrooms" class="form-control" />
        <span asp-validation-for="Bedrooms" class="text-danger"></span>
    </div>
    <div class="col-md-4 form-group mb-3">
        <label asp-for="Bathrooms" class="control-label"></label>
        <input asp-for="Bathrooms" class="form-control" />
        <span asp-validation-for="Bathrooms" class="text-danger"></span>
    </div>
    <div class="col-md-4 form-group mb-3">
        <label asp-for="YearBuilt" class="control-label"></label>
        <input asp-for="YearBuilt" class="form-control" />
        <span asp-validation-for="YearBuilt" class="text-danger"></span>
    </div>
</div>

<div class="form-group mb-3">
    <label asp-for="LegalStatus" class="control-label"></label>
    <select asp-for="LegalStatus" class="form-control" asp-items="ViewBag.LegalStatus">
        <option value="">-- Select status --</option>
    </select>
    <span asp-validation-for="LegalStatus" class="text-danger"></span>
</div>

<div class="form-group mb-3">
    <label asp-for="CurrentOwnerId" class="control-label">Owner</label>
    <select asp-for="CurrentOwnerId" class="form-control" asp-items="ViewBag.CurrentOwnerId">
        <option value="">-- Select owner --</option>
    </select>
    <span asp-validation-for="CurrentOwnerId" class="text-danger"></span>
</div>

<div class="form-group mb-3">
    <label for="featuresText" class="control-label">Features (comma-separated)</label>
    <textarea id="featuresText" name="featuresText" class="form-control" rows="2">@(Model.Features != null ? string.Join(", ", Model.Features) : "")</textarea>
</div>

<div class="form-group mb-3">
    <label asp-for="Images" class="control-label">Photos</label>
    <input asp-for="Images" type="file" class="form-control" multiple accept=".png,.jpg,.jpeg" />
    <span asp-validation-for="Images" class="text-danger"></span>
</div>

@if (Model.ImagesNames?.Count > 0)
{
    <div class="form-group mb-3">
        <label class="control-label">Current Photos</label>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var image in Model.ImagesNames)
            {
                <img src="~/Files/Properties/@image" alt="Property photo" class="img-thumbnail" style="max-height: 80px;" />
            }
        </div>
    </div>
}
