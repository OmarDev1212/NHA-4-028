@model Sakan.Application.DTO.MaintenanceRequestDto
@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>
<p><strong>Property:</strong> @Model.PropertyTitle</p>
<p><strong>Status:</strong> @Model.Status · <strong>Priority:</strong> @Model.Priority</p>
<p>@Model.Description</p>
@if (Model.EstimatedCostUSD.HasValue)
{
    <p><strong>Estimated:</strong> @Model.EstimatedCostUSD USD</p>
}
@if (Model.ActualCostUSD.HasValue)
{
    <p><strong>Actual:</strong> @Model.ActualCostUSD USD</p>
}

<a asp-action="Assign" asp-route-id="@Model.Id" class="btn btn-primary">Assign contractor</a>

<form asp-action="Resolve" asp-route-id="@Model.Id" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <div class="input-group" style="max-width:320px;">
        <input type="number" name="actualCost" step="0.01" class="form-control" placeholder="Actual cost (optional)" />
        <button type="submit" class="btn btn-success">Resolve</button>
    </div>
</form>

<a asp-action="Index" class="btn btn-link mt-3">Back</a>