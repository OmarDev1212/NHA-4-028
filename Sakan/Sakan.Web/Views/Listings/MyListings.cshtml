@model IEnumerable<Sakan.Application.DTO.PropertyListingDto>
@{
    ViewData["Title"] = "My listings";
}

<h1>My listings</h1>
<p><a asp-action="Create" class="btn btn-primary">New listing</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Property</th>
            <th>Type</th>
            <th>Price</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.PropertyTitle</td>
            <td>@item.ListingType</td>
            <td>@item.Price @item.Currency</td>
            <td>@item.Status</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">View</a>
                @if (item.Status == nameof(Sakan.Domain.Enums.ListingStatus.Draft))
                {
                    <form asp-action="Publish" asp-route-id="@item.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link btn-sm p-0">Publish</button>
                    </form>
                }
                @if (item.ListingType == nameof(Sakan.Domain.Enums.ListingType.ForRent))
                {
                    <a asp-controller="RentalApplications" asp-action="ForListing" asp-route-listingId="@item.Id">Applications</a>
                }
                <form asp-action="Withdraw" asp-route-id="@item.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Withdraw</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>